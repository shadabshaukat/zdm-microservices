# Runtime defaults for ZEUS (backend + Streamlit)
# Base dir for runtime artifacts (config, auth, certs)
ZEUS_BASE=/u01/zeus

# Ports / host
ZEUS_HOST=127.0.0.1
ZEUS_PORT=8001
STREAMLIT_PORT=8000

# TLS paths (derived from ZEUS_BASE)
ZEUS_CERT_DIR=$ZEUS_BASE/certs
ZEUS_SSL_CERTFILE=$ZEUS_CERT_DIR/zeus.crt
ZEUS_SSL_KEYFILE=$ZEUS_CERT_DIR/zeus.key
STREAMLIT_SSL_CERT=$ZEUS_SSL_CERTFILE
STREAMLIT_SSL_KEY=$ZEUS_SSL_KEYFILE
REQUESTS_CA_BUNDLE=$ZEUS_SSL_CERTFILE

# Config/auth locations (derived from ZEUS_BASE)
ZEUS_RUNTIME_ENV=$ZEUS_BASE/zeus.env
ZEUS_AUTH_FILE=$ZEUS_BASE/.zeus.auth.env

# Frontend -> backend
API_BASE_URL=https://localhost:${ZEUS_PORT}
