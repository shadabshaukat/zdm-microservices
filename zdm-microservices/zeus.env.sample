# Runtime defaults for ZEUS (backend + Streamlit)
# Keep this minimal: set source variables only. Derived paths (certs/auth/logs)
# are computed from ZEUS_BASE by the startup/restart scripts.

# Base directories
ZEUS_DATA=/u01/data        # parent for migration working state
ZEUS_BASE=/u01/data/zeus   # runtime config/auth/certs/logs

# Network
ZEUS_HOST=127.0.0.1
ZEUS_PORT=8001
STREAMLIT_PORT=8000

# Optional override for UI -> backend URL (otherwise derived from ZEUS_PORT)
# API_BASE_URL=https://localhost:${ZEUS_PORT}
